{
  "expo": {
    "name": "TransitHub",
    "slug": "transit-hub",
    "privacy": "public",
    "version": "1.0.0",
    "scheme": "transithub",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#020E1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.transithub.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#020E1A"
      },
      "package": "com.transithub.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8255242c-f94f-4247-b5ab-948eac481e37"
      }
    },
    "plugins": [
      "expo-font",
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C9A84C",
          "sounds": []
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8255242c-f94f-4247-b5ab-948eac481e37"
    }
  }
}
